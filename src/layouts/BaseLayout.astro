---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import DiscountPopup from "../components/ui/DiscountPopup.astro";
import { bathAssets, site } from "../data/site";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  showPopup?: boolean;
  bodyClass?: string;
}

const {
  title,
  description,
  canonical = new URL(Astro.url.pathname, site.url).toString(),
  noindex = false,
  schema = [],
  showPopup = true,
  bodyClass = ""
} = Astro.props;

const schemaItems = Array.isArray(schema) ? schema : [schema];
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={site.icon} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={bathAssets.hero} />
    <meta name="twitter:card" content="summary_large_image" />
    {schemaItems.map((item) => <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />)}
  </head>
  <body class={bodyClass}>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    {showPopup && <DiscountPopup />}
  </body>
</html>
