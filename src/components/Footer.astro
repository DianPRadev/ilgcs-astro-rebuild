---
import { navItems, servicePages, site, towns } from "../data/site";
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <img src={site.logo} alt={`${site.name} logo`} width="300" height="92" loading="lazy" />
        <p>
          Kitchen remodeling, bathroom remodeling, flooring, decks, masonry, basements, and general construction services
          for Schaumburg and nearby Illinois communities.
        </p>
      </div>
      <div>
        <h3>Services</h3>
        <ul>
          {servicePages.slice(0, 6).map((service) => <li><a href={`/${service.slug}/`}>{service.title}</a></li>)}
          <li><a href="/bath/">Walk-In Shower Offer</a></li>
        </ul>
      </div>
      <div>
        <h3>Navigation</h3>
        <ul>
          {navItems.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
        </ul>
      </div>
      <div>
        <h3>Service Areas</h3>
        <ul>
          {towns.slice(0, 6).map((town) => <li><a href={`/bathroom-remodeling/${town.slug}/`}>{town.name}, IL</a></li>)}
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; {new Date().getFullYear()} {site.name}. All rights reserved.</span>
    </div>
  </div>
</footer>
