---
import { companyAssets, site } from "../../data/site";

interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  image?: string;
  imagePosition?: string;
  ctaHref?: string;
  ctaLabel?: string;
  viewportFit?: boolean;
}

const {
  eyebrow = site.shortName,
  title,
  subtitle,
  image = companyAssets.hero,
  imagePosition = "center",
  ctaHref = "/request-a-quote/",
  ctaLabel = "Request a Quote",
  viewportFit = false
} = Astro.props;

const showSecondaryCall = ctaHref !== site.phoneHref;
---

<section
  class:list={["page-hero", viewportFit && "page-hero-fit"]}
  style={`--page-hero-image: url('${image}'); --page-hero-position: ${imagePosition};`}
>
  <div class="container page-hero-inner">
    <div>
      <span class="eyebrow">{eyebrow}</span>
      <h1>{title}</h1>
      <p>{subtitle}</p>
      <div class="hero-actions">
        <a class="btn" href={ctaHref}>{ctaLabel}</a>
        {showSecondaryCall && <a class="btn btn-outline" href={site.phoneHref}>Call {site.phone}</a>}
      </div>
    </div>
  </div>
</section>
