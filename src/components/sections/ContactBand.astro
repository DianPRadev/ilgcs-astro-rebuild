---
import LeadForm from "../ui/LeadForm.astro";
import { site } from "../../data/site";
---

<section class="section section-blue" id="contact">
  <div class="container contact-grid">
    <div class="contact-info">
      <h2>Ready to update your bathroom?</h2>
      <p>
        Request a bath remodel estimate, ask about current discount offers, or call ILGCS directly for help choosing
        the right next step.
      </p>
      <ul class="contact-list">
        <li><strong>Phone:</strong> <a href={site.phoneHref}>{site.phone}</a></li>
        <li><strong>Email:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></li>
        <li><strong>Office:</strong> <a href={site.mapUrl} target="_blank" rel="noreferrer">{site.address}</a></li>
      </ul>
    </div>
    <LeadForm
      formName="contact-estimate"
      title="Get A Free Estimate"
      subtitle="Send your bathroom remodel details and the team will follow up."
      service="Bathroom Remodel Estimate"
      buttonText="Submit"
    />
  </div>
</section>
