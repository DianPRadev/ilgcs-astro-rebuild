---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactBand from "../components/sections/ContactBand.astro";
import PageHero from "../components/sections/PageHero.astro";
import ServicesGrid from "../components/sections/ServicesGrid.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import { companyAssets, companyProof, localBusinessSchema, portfolioItems, servicePages } from "../data/site";
import { withBase } from "../utils/url";
---

<BaseLayout
  title="Kitchen and Bathroom Remodeling Services, Illinois - ILGCS"
  description="IL General Construction Services provides kitchen remodeling, bathroom remodeling, flooring, deck building, masonry, basement remodeling, and construction services near Schaumburg, IL."
  canonical="https://ilgcs.com/"
  schema={localBusinessSchema}
>
  <PageHero
    eyebrow="General Construction Services"
    title="Kitchen and bathroom remodeling services in Illinois"
    subtitle="ILGCS helps homeowners plan and complete practical remodeling projects with clean workmanship, clear communication, and local service from Schaumburg."
    image={companyAssets.hero}
    viewportFit={true}
  />

  <section class="section section-soft">
    <div class="container">
      <div class="stat-grid">
        {companyProof.map((item) => (
          <div class="stat-card">
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="services">
    <div class="container">
      <h2 class="section-title">Remodeling and construction services</h2>
      <p class="section-lede">
        The original ILGCS site covers more than bath remodeling. These are the core service pages now rebuilt in Astro.
      </p>
      <ServicesGrid />
    </div>
  </section>

  <section class="section section-soft">
    <div class="container split-section">
      <div>
        <h2>Built for real homes, not showroom-only designs</h2>
        <p>
          From kitchen layouts to bathroom safety upgrades, ILGCS focuses on practical construction details: measurements,
          sequencing, finish selection, and clean installation.
        </p>
        <ul class="check-list">
          <li>Kitchen, bathroom, basement, flooring, deck, and masonry work</li>
          <li>Local service for Schaumburg and nearby Illinois communities</li>
          <li>Estimate-first process with clear scope before work begins</li>
        </ul>
        <a class="btn" href={withBase("/services/")}>View All Services</a>
      </div>
      <div class="image-stack">
        {companyAssets.icons.map((image, index) => (
          <img src={image} alt={`ILGCS project detail ${index + 1}`} loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Portfolio preview</h2>
      <p class="section-lede">A quick look at the type of kitchen, bath, and safety-focused remodeling work the site needs to showcase.</p>
      <div class="portfolio-grid compact">
        {portfolioItems.slice(0, 6).map((item) => (
          <a class="portfolio-card" href={withBase(item.href)} aria-label={`View related service for ${item.title}`}>
            <img src={item.image} alt={item.title} loading="lazy" />
            <div>
              <span>{item.category}</span>
              <h3>{item.title}</h3>
            </div>
          </a>
        ))}
      </div>
      <div class="centered-action">
        <a class="btn btn-blue" href={withBase("/portfolio/")}>View Portfolio</a>
      </div>
    </div>
  </section>

  <Testimonials />

  <section class="section section-soft">
    <div class="container">
      <h2 class="section-title">Popular service links</h2>
      <div class="area-list service-link-list">
        {servicePages.map((service) => <a href={withBase(`/${service.slug}/`)}>{service.title}</a>)}
        <a href={withBase("/bath/")}>Walk-In Shower Offer</a>
      </div>
    </div>
  </section>

  <ContactBand
    heading="Ready to update your home?"
    text="Request a remodeling or construction estimate, ask about the best next step, or call ILGCS directly."
    formName="home-general-estimate"
    formSubtitle="Send your project details and the team will follow up."
    service="General Remodeling Estimate"
  />
</BaseLayout>
