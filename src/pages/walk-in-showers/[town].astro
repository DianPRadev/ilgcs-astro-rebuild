---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ColorPatterns from "../../components/sections/ColorPatterns.astro";
import ContactBand from "../../components/sections/ContactBand.astro";
import EstimateWizard from "../../components/sections/EstimateWizard.astro";
import Hero from "../../components/sections/Hero.astro";
import InstallationOptions from "../../components/sections/InstallationOptions.astro";
import ServiceAreaSeo from "../../components/sections/ServiceAreaSeo.astro";
import Testimonials from "../../components/sections/Testimonials.astro";
import { faqSchema, localBusinessSchema, serviceSchema, towns } from "../../data/site";

export function getStaticPaths() {
  return towns.map((town) => ({ params: { town: town.slug }, props: { town } }));
}

const { town } = Astro.props;
---

<BaseLayout
  title={`Walk-In Shower Installation in ${town.name}, IL | ILGCS`}
  description={`Get a walk-in shower estimate in ${town.name}, IL. ILGCS offers one-day installation options, low-threshold showers, grab bars, seats, and modern wall systems.`}
  canonical={`https://ilgcs.com/walk-in-showers/${town.slug}/`}
  schema={[localBusinessSchema, serviceSchema("Walk-In Shower Installation", town.name), faqSchema()]}
>
  <Hero
    title={`Stylish <b>walk-in showers</b> in ${town.name}, IL`}
    subtitle="Choose the finish, safety features, doors, and accessories. ILGCS handles the shower installation."
    service={`Walk-In Shower Installation in ${town.name}, IL`}
  />
  <ServiceAreaSeo town={town.name} service="walk-in shower installation" />
  <InstallationOptions />
  <ColorPatterns />
  <EstimateWizard />
  <Testimonials />
  <ContactBand />
</BaseLayout>
