---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactBand from "../../components/sections/ContactBand.astro";
import PageHero from "../../components/sections/PageHero.astro";
import { blogPosts, companyAssets, localBusinessSchema } from "../../data/site";
import { withBase } from "../../utils/url";
---

<BaseLayout
  title="Blog | ILGCS Remodeling Advice"
  description="ILGCS blog archive for remodeling planning, bathroom safety, kitchen remodeling scope, and local contractor guidance."
  canonical="https://ilgcs.com/category/blog/"
  schema={localBusinessSchema}
>
  <PageHero
    eyebrow="Blog"
    title="Remodeling advice and project planning"
    subtitle="A rebuilt blog archive route so the Astro site has the same main blog destination as the original WordPress site."
    image={companyAssets.pattern}
  />

  <section class="section">
    <div class="container">
      <h2 class="section-title">Latest guides</h2>
      <div class="blog-grid">
        {blogPosts.map((post) => (
          <article class="blog-card">
            <span>ILGCS Guide</span>
            <h3><a href={withBase(post.href)}>{post.title}</a></h3>
            <p>{post.excerpt}</p>
            <a class="text-link" href={withBase(post.href)}>Read more</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ContactBand
    heading="Have a remodeling question?"
    text="Send the project details and ILGCS will help clarify scope, timing, and the next step."
    formName="blog-estimate"
    formSubtitle="Send your project details and the team will follow up."
    service="Blog Inquiry"
  />
</BaseLayout>
