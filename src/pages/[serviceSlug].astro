---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactBand from "../components/sections/ContactBand.astro";
import PageHero from "../components/sections/PageHero.astro";
import ServicesGrid from "../components/sections/ServicesGrid.astro";
import LeadForm from "../components/ui/LeadForm.astro";
import { localBusinessSchema, servicePages, serviceSchema } from "../data/site";

export function getStaticPaths() {
  return servicePages.flatMap((service) => {
    const slugs = [service.slug, ...service.aliases];
    return slugs.map((slug) => ({ params: { serviceSlug: slug }, props: { service, slug } }));
  });
}

const { service, slug } = Astro.props;
const canonicalSlug = service.slug;
---

<BaseLayout
  title={service.seoTitle}
  description={service.seoDescription}
  canonical={`https://ilgcs.com/${canonicalSlug}/`}
  schema={[localBusinessSchema, serviceSchema(service.title)]}
>
  <PageHero
    eyebrow="Service"
    title={service.title}
    subtitle={service.summary}
    image={service.image}
    imagePosition={service.heroImagePosition}
    ctaLabel="Request Estimate"
  />

  <section class="section">
    <div class="container service-detail-layout">
      <article class="content-panel">
        {slug !== canonicalSlug && (
          <p class="notice">This legacy URL is supported and points to the current {service.title} page.</p>
        )}
        <h2>{service.title} from ILGCS</h2>
        <p>{service.description}</p>
        <h3>What this service can include</h3>
        <ul class="check-list">
          {service.highlights.map((item) => <li>{item}</li>)}
          <li>Project estimate and scope review</li>
          <li>Service for Schaumburg and nearby Illinois communities</li>
        </ul>
        <p>
          This page is intentionally static and indexable so it can support service searches while still sending estimate
          requests through the shared lead form.
        </p>
      </article>
      <aside class="sticky-card">
        <LeadForm
          formName={`${canonicalSlug}-estimate`}
          title={`Request ${service.title} Estimate`}
          subtitle="Tell us about the project and the team will follow up."
          service={service.title}
          buttonText="Request Estimate"
        />
      </aside>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <h2 class="section-title">More ILGCS services</h2>
      <ServicesGrid limit={3} />
    </div>
  </section>

  <ContactBand
    heading={`Ready to discuss ${service.title.toLowerCase()}?`}
    text="Request an estimate, ask about scope, or call ILGCS directly for help choosing the right next step."
    formName={`${canonicalSlug}-contact`}
    formSubtitle="Send your project details and the team will follow up."
    service={`${service.title} Estimate`}
  />
</BaseLayout>
